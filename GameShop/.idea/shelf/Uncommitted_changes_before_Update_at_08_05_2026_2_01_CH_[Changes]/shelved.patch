+// src/routes/gameRoutes.js
+const express        = require('express');
+const router         = express.Router();
 const gameController = require('../controllers/gameController');
 
+// GET /api/games/stats         → thống kê tổng quan
+router.get('/stats', gameController.getStats);
+
+// GET /api/games/featured      → top games nổi bật (theo rating)
+router.get('/featured', gameController.getFeaturedGames);
+
+// GET /api/games/search?q=xxx  → tìm kiếm theo tên
+router.get('/search', gameController.searchGames);
+
+// GET /api/games/genres        → danh sách thể loại + số lượng
+router.get('/genres', gameController.getGenres);
+
+// GET /api/games               → danh sách có filter & phân trang
+// Query: page, limit, genre, sort (popular|price_asc|price_desc|newest|rating|metacritic), free, platform
 router.get('/', gameController.getGames);
 
+// GET /api/games/:id           → chi tiết 1 game theo steam_appid
+router.get('/:id', gameController.getGameById);
+
 module.exports = router;
